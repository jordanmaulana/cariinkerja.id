# Copy to .env (host dev) or .env.docker (compose). Both are gitignored.

# --- Django ---
SECRET_KEY=
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins for django-cors-headers + CSRF_TRUSTED_ORIGINS.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Database ---
# Leave POSTGRES_HOST empty for SQLite (host dev default).
# In compose, set POSTGRES_HOST=postgres.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# --- Celery / Redis ---
# Host dev: redis://localhost:6379/0. Compose: redis://redis:6379/0.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- OpenAI — required for assessment task. Leave key empty to disable. ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-2024-08-06

# --- Google OAuth — Web Client ID from Google Cloud Console.
# Must match VITE_GOOGLE_CLIENT_ID in frontend/.env. ---
GOOGLE_OAUTH_CLIENT_ID=

# --- Mayar (payments) ---
MAYAR_API_KEY=
MAYAR_WEBHOOK_TOKEN=
MAYAR_BASE_URL=https://api.mayar.club/hl/v1
PAYMENT_REDIRECT_URL=http://localhost:5173/plans

# --- Discord notifications (optional) ---
# Incoming webhook URL. Leave empty to disable.
DISCORD_WEBHOOK_URL=
# Public base URL for admin links in notifications (no trailing slash).
SITE_URL=http://localhost:8000
# Public base URL of the SPA (used for transactional email links). No trailing slash.
FRONTEND_URL=http://localhost:5173

# --- Email (SMTP, outgoing only) ---
# Mailbox is hosted on mailspace.id; the TLS cert at mail.cariinkerja.id
# is for mx2.mailspace.id, so connect there directly to pass hostname
# verification. 465 + SSL also works (set EMAIL_PORT=465, EMAIL_USE_SSL=True,
# EMAIL_USE_TLS=False). EMAIL_USE_SSL and EMAIL_USE_TLS are mutually exclusive.
EMAIL_HOST=mx2.mailspace.id
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=

# --- Frontend build args (consumed by frontend/Dockerfile via compose) ---
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=

# --- Cloudflare tunnel (compose-managed cloudflared service) ---
# Token from Cloudflare Zero Trust dashboard. Tunnel ingress must point at
# http://backend:8000 and http://frontend:3000 over the compose network.
CLOUDFLARE_TUNNEL_TOKEN=
